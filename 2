<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Web Page</title>

    <!-- 字体 & 图标 -->
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Work Sans', sans-serif;
            background: url('https://i.imgur.com/HbnThd1.png') no-repeat center center fixed;
            /* 你可以替换成你自己的背景图 */
            background-size: cover;
        }

        header,
        footer {
            background-color: #4CAF50;
            color: white;
            text-align: center;
            padding: 10px 0;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 30px;
        }

        header .logo {
            font-weight: bold;
            font-size: 1.2rem;
        }

        header .icons a {
            color: white;
            margin-left: 10px;
            font-size: 1.2rem;
            text-decoration: none;
        }

        .profile {
            text-align: center;
            padding: 40px 20px;
        }

        .profile img {
            width: 100px;
            border-radius: 50%;
            margin-bottom: 15px;
        }

        .profile h2 {
            margin: 5px 0;
        }

        .profile p {
            max-width: 600px;
            margin: 0 auto;
            color: #333;
            font-size: 0.95rem;
        }

        .weeks {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            padding: 20px;
        }

        .card {
            width: 250px;
            background: rgba(255, 255, 255, 0.75);
            border-radius: 16px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            padding: 20px;
            backdrop-filter: blur(5px);
        }

        .card h3 {
            font-weight: 600;
            font-size: 1.2em;
            display: flex;
            align-items: center;
            border-bottom: 1px solid #000;
            padding-bottom: 10px;
            margin-bottom: 10px;
        }

        .card h3 i {
            margin-right: 8px;
        }

        .card ul {
            list-style: none;
            padding-left: 0;
            margin: 0;
        }

        .card ul li {
            margin-bottom: 8px;
        }

        footer {
            font-size: 0.85rem;
        }

        /* RWD 手机屏幕样式 */
        @media screen and (max-width: 375px) {
            .weeks {
                flex-direction: column;
                align-items: center;
            }

            .card {
                width: 90%;
            }

            header {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>

<body>
    <!-- 顶部导航 -->
    <header>
        <div class="logo">LOGO</div>
        <div class="icons">
            <a href="#"><i class="fab fa-twitter"></i></a>
            <a href="#"><i class="fab fa-linkedin"></i></a>
            <a href="#"><i class="fab fa-github"></i></a>
        </div>
    </header>

    <!-- 个人资料区域 -->
    <div class="profile">
        <img src="https://via.placeholder.com/100" alt="Profile">
        <h2>Your Name</h2>
        <p>Web Publishing</p>
        <p>Hello! I'm [Your Name], a [Your Profession]. I love [a few things you love or are passionate about]. Welcome
            to my personal page!</p>
    </div>

    <!-- 格子卡片区域 -->
    <div class="weeks">
        <div class="card">
            <h3><i class="fa-regular fa-calendar"></i> Week 2</h3>
            <ul>
                <li>Exercise 1</li>
                <li>Exercise 2</li>
            </ul>
        </div>

        <div class="card">
            <h3><i class="fa-regular fa-calendar"></i> Week 3</h3>
            <ul>
                <li>Exercise 1</li>
                <li>Exercise 2</li>
            </ul>
        </div>

        <div class="card">
            <h3><i class="fa-regular fa-calendar"></i> Week 4</h3>
            <ul>
                <li>Exercise 1</li>
                <li>Exercise 2</li>
            </ul>
        </div>

        <div class="card">
            <h3><i class="fa-regular fa-calendar"></i> Week 5</h3>
            <ul>
                <li>Exercise 1</li>
                <li>Exercise 2</li>
            </ul>
        </div>
    </div>

    <!-- 页脚 -->
    <footer>
        <p>© 2024 [Your Name]. All rights reserved.</p>
    </footer>
</body>

</html>