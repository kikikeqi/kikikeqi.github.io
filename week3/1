<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigation Bar</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        .flex-container {
            display: flex;
            justify-content: space-between;
            /* Space between logo and nav items */
            align-items: center;
            background-color: #2d65bc;
            padding: 10px 20px;
        }

        .flex-container img {
            margin-right: 20px;
            /* Add some space between the logo and the buttons */
        }

        .nav-buttons {
            display: flex;
            gap: 20px;
            /* Space between buttons */
        }

        .nav-buttons div {
            color: white;
            cursor: pointer;
            position: relative;
        }

        .nav-buttons div::after {
            content: '';
            display: block;
            width: 0;
            height: 2px;
            background: white;
            transition: width .3s;
            position: absolute;
            bottom: -5px;
            left: 0;
        }

        .nav-buttons div:hover::after {
            width: 100%;
        }
    </style>
</head>

<body>
    <div class="flex-container">
        <div><img src="photofile/coffelogo.png" width="50" alt="kiki"></div>
        <div class="nav-buttons">
            <div>Home</div>
            <div>About</div>
            <div>Services</div>
            <div>Team</div>
            <div>Contact</div>
        </div>
    </div>
</body>

</html>